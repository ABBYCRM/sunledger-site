# Set these in your hosting platform's environment variables.
# NEVER commit a real .env file.

# Brand name displayed across the site
NEXT_PUBLIC_BRAND_NAME=Sunledger

# Canonical production URL — used in absolute URLs, sitemap.xml, robots.txt
NEXT_PUBLIC_SITE_URL=https://sunledger-site.onrender.com

# Formspree-shaped endpoint for the intake form.
# Leave empty to fall back to mailto: behavior.
NEXT_PUBLIC_CONTACT_ENDPOINT=
